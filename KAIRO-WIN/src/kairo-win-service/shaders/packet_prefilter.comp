void main() {
    uint index = gl_GlobalInvocationID.x;
    if (index >= params.word_count) {
        return;
    }

    if (index == 0) {
        output_metrics.metrics[0] = params.total_bytes;
    }

    uint packed = input_words.words[index];
    for (uint shift = 0; shift < 4; ++shift) {
        uint byte_index = index * 4 + shift;
        if (byte_index >= params.total_bytes) {
            break;
        }
        uint value = (packed >> (shift * 8)) & 0xffu;
        if (value >= 32u && value <= 126u) {
            atomicAdd(output_metrics.metrics[1], 1u);
        }
        if (value >= 128u) {
            atomicAdd(output_metrics.metrics[3], 1u);
        }
        if (is_delimiter(value)) {
            atomicAdd(output_metrics.metrics[2], 1u);
        }

        // --- Red Word Scanning at this byte position ---
        
        // TECH
        for (uint w = 0; w < TECH_WORD_COUNT; ++w) {
            uint w_len = TECH_LENGTHS[w];
            if (byte_index + w_len > params.total_bytes) continue;
            bool matched = true;
            for (uint i = 0; i < w_len; ++i) {
                uint target_byte = (TECH_WORDS_PACKED[TECH_OFFSETS[w] + (i / 4)] >> ((i % 4) * 8)) & 0xffu;
                if (get_byte(byte_index + i) != target_byte) {
                    matched = false;
                    break;
                }
            }
            if (matched) atomicAdd(output_metrics.metrics[4], 1u);
        }

        // HARM
        for (uint w = 0; w < HARM_WORD_COUNT; ++w) {
            uint w_len = HARM_LENGTHS[w];
            if (byte_index + w_len > params.total_bytes) continue;
            bool matched = true;
            for (uint i = 0; i < w_len; ++i) {
                uint target_byte = (HARM_WORDS_PACKED[HARM_OFFSETS[w] + (i / 4)] >> ((i % 4) * 8)) & 0xffu;
                if (get_byte(byte_index + i) != target_byte) {
                    matched = false;
                    break;
                }
            }
            if (matched) atomicAdd(output_metrics.metrics[5], 1u);
        }

        // CONCEAL
        for (uint w = 0; w < CONCEAL_WORD_COUNT; ++w) {
            uint w_len = CONCEAL_LENGTHS[w];
            if (byte_index + w_len > params.total_bytes) continue;
            bool matched = true;
            for (uint i = 0; i < w_len; ++i) {
                uint target_byte = (CONCEAL_WORDS_PACKED[CONCEAL_OFFSETS[w] + (i / 4)] >> ((i % 4) * 8)) & 0xffu;
                if (get_byte(byte_index + i) != target_byte) {
                    matched = false;
                    break;
                }
            }
            if (matched) atomicAdd(output_metrics.metrics[6], 1u);
        }
    }
}
