#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PrefilterParams {
    uint total_bytes;
    uint word_count;
} params;

layout(set = 0, binding = 0) readonly buffer InputWords {
    uint words[];
} input_words;

layout(set = 0, binding = 1) buffer OutputMetrics {
    uint metrics[7]; // 0: total, 1: ascii, 2: delim, 3: non-ascii, 4: tech, 5: harm, 6: conceal
} output_metrics;

#include "red_words.glsl"

bool is_delimiter(uint value) {
    return value == 47u  // /
        || value == 58u  // :
        || value == 63u  // ?
        || value == 38u  // &
        || value == 61u  // =
        || value == 37u  // %
        || value == 46u  // .
        || value == 95u  // _
        || value == 45u; // -
}

uint get_byte(uint byte_idx) {
    uint word_idx = byte_idx / 4;
    uint shift = (byte_idx % 4) * 8;
    return (input_words.words[word_idx] >> shift) & 0xffu;
}

bool match_word(uint start_byte, uint word_len, uint packed_offset) {
    if (start_byte + word_len > params.total_bytes) return false;
    
    for (uint i = 0; i < word_len; ++i) {
        uint p_word = TECH_WORDS_PACKED[packed_offset + (i / 4)]; // This is tricky because we have 3 arrays
